<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Foro Readme</title>
    <meta charset="utf-8" />

    @Styles.Render("~/Content/css")

    <!-- CSS del foro -->
    <link href="@Url.Content("~/Content/forum.css")" rel="stylesheet" />

    @Scripts.Render("~/bundles/modernizr")
</head>

<body>

    <nav class="navbar navbar-inverse">
        <div class="container">

            <div class="navbar-header">
                <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#menu">
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                    <span class="icon-bar"></span>
                </button>

                @Html.ActionLink("Foro Readme", "Index", "Home", null, new { @class = "navbar-brand" })
            </div>

            <div class="collapse navbar-collapse" id="menu">
                <ul class="nav navbar-nav">

                    <li>@Html.ActionLink("Inicio", "Index", "Home")</li>
                    <li>@Html.ActionLink("Comunidades", "Index", "Comunidad")</li>

                    @if (Session["UsuarioId"] != null)
                    {
                        <li>@Html.ActionLink("Mi Perfil", "Details", "Usuarios", new { id = Session["UsuarioId"] }, null)</li>

                        <li>
                            @using (Html.BeginForm("Logout", "Account", FormMethod.Post))
                            {
                                <button type="submit" class="btn btn-link navbar-btn">Cerrar sesión</button>
                            }
                        </li>
                    }
                    else
                    {
                        <li>@Html.ActionLink("Login", "Login", "Account")</li>
                        <li>@Html.ActionLink("Registro", "Register", "Account")</li>
                    }

                </ul>
            </div>

        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()

        <hr />

        <footer>
            <p>&copy; @DateTime.Now.Year - Foro Readme</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    @RenderSection("scripts", required: false)

</body>
</html>