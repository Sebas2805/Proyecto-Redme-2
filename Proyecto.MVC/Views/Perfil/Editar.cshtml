@model Proyecto.Data.usuario

<div style="max-width:500px; margin:30px auto; font-family:Arial, sans-serif;">

    <a href="@Url.Action("Index", "Perfil", new { id = Model.id_usuario })" style="
    display:inline-flex;
    align-items:center;
    gap:6px;
    text-decoration:none;
    color:#555;
    font-size:14px;
    padding:8px 14px;
    border:1px solid #ccc;
    border-radius:8px;
    background:#f9f9f9;
    margin-bottom:15px;
">
        ← Volver
    </a>

    <h2>Editar Perfil</h2>

    @using (Html.BeginForm("Editar", "Perfil", FormMethod.Post))
    {
        @Html.HiddenFor(m => m.id_usuario)

        <div style="margin-bottom:15px;">
            <label><strong>Nombre de usuario</strong></label><br />
            @Html.TextBoxFor(m => m.nombre_usuario, new { style = "width:100%; padding:8px; margin-top:5px;" })
        </div>

        <div style="margin-bottom:15px;">
            <label><strong>Foto de perfil</strong></label><br />
            <input type="file" id="edit-foto-input" accept="image/*" style="margin-top:5px;" />
            <input type="hidden" name="fotoPerfil" id="edit-foto-url" />

            <div style="margin-top:10px; display:flex; align-items:center; gap:10px;">
                <div>
                    <p style="margin:0; color:#666; font-size:13px;">Foto actual:</p>
                    <img id="edit-foto-img" src="@(string.IsNullOrEmpty(Model.foto_perfil) ? "/Fotos/default.png" : Model.foto_perfil)" width="80" height="80"
                         style="border-radius:50%; object-fit:cover; margin-top:5px; border:2px solid #ccc;" />
                </div>
                <span id="edit-foto-status" style="font-size:13px; color:#666;"></span>
            </div>
        </div>

        <div style="display:flex; gap:10px; margin-top:20px;">
            <button type="submit" id="edit-submit-btn" style="padding:8px 20px; background:#007bff; color:white; border:none; border-radius:4px; cursor:pointer;">
                Guardar
            </button>
            @Html.ActionLink("Cancelar", "Index", "Perfil",
                new { id = Model.id_usuario },
                new { style = "padding:8px 20px; background:#6c757d; color:white; border-radius:4px; text-decoration:none;" })
        </div>
    }

</div>

@section scripts {
    <script src="https://www.gstatic.com/firebasejs/10.11.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.11.0/firebase-storage-compat.js"></script>
    <script>
        firebase.initializeApp({
            apiKey: "AIzaSyDOdAjPpkEY3Dcrj9lvLm42K3v1qGoIQVk",
            authDomain: "proyecto-readme.firebaseapp.com",
            projectId: "proyecto-readme",
            storageBucket: "proyecto-readme.firebasestorage.app",
            messagingSenderId: "338116848794",
            appId: "1:338116848794:web:6ec96caf8cd54ae59d0323"
        });

        var storage = firebase.storage();
        var submitBtn = document.getElementById('edit-submit-btn');
        var fotoInput = document.getElementById('edit-foto-input');
        var fotoUrl = document.getElementById('edit-foto-url');
        var fotoImg = document.getElementById('edit-foto-img');
        var fotoStatus = document.getElementById('edit-foto-status');

        fotoInput.addEventListener('change', function () {
            var file = fotoInput.files[0];
            if (!file) return;

            fotoImg.src = URL.createObjectURL(file);
            fotoStatus.textContent = 'Subiendo...';
            submitBtn.disabled = true;

            var userId = document.querySelector('input[name="id_usuario"]').value;
            var ext = file.name.split('.').pop();
            var nombre = 'fotos-perfil/user_' + userId + '_' + Date.now() + '.' + ext;
            var ref = storage.ref(nombre);

            ref.put(file).then(function (snapshot) {
                return snapshot.ref.getDownloadURL();
            }).then(function (url) {
                fotoUrl.value = url;
                fotoStatus.textContent = 'Foto lista';
                submitBtn.disabled = false;
            }).catch(function (err) {
                fotoStatus.textContent = 'Error al subir la imagen. Intentá de nuevo.';
                fotoUrl.value = '';
                submitBtn.disabled = false;
                console.error(err);
            });
        });
    </script>
}