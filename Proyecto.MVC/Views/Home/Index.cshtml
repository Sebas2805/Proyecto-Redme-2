@{
    ViewBag.Title = "Inicio";
    bool isAuth = Session["UsuarioId"] != null;
}

<div class="row home-layout">

    @* columna principal (feed) *@
    <div class="col-md-8">
        @if (isAuth)
        {
            <div class="home-feed-card surface-card">
                <div class="home-feed-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 3.2 3.8 10v10.2h5.7v-6.1h5v6.1h5.7V10L12 3.2z"/>
                    </svg>
                </div>
                <h2 class="home-feed-heading">Bienvenido, <strong>@Session["NombreUsuario"]</strong></h2>
                <p class="home-feed-desc">Explora comunidades, comparte conocimiento y conecta con otros desarrolladores.</p>
                <div class="home-feed-actions">
                    <a href="@Url.Action("Index", "Comunidad")" class="btn btn-primary-strong">Explorar comunidades</a>
                </div>
            </div>
        }
        else
        {
            <div class="home-feed-card surface-card">
                <div class="home-feed-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 3.2 3.8 10v10.2h5.7v-6.1h5v6.1h5.7V10L12 3.2z"/>
                    </svg>
                </div>
                <h2 class="home-feed-heading">Foro Readme</h2>
                <p class="home-feed-desc">Comparte ideas, resuelve dudas y participa en debates con una comunidad técnica activa.</p>
                <div class="home-feed-actions">
                    <a href="@Url.Action("Login", "Account")" class="btn btn-primary-strong">Iniciar sesión</a>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-ghost">Registrarse</a>
                </div>
            </div>
        }
    </div>

    @* sidebar derecha *@
    <div class="col-md-4">
        @if (isAuth)
        {
            <aside class="home-sidebar-card surface-card">
                <div class="home-sidebar-banner" aria-hidden="true"></div>
                <div class="home-sidebar-body">
                    <h6 class="home-sidebar-title">Inicio</h6>
                    <p class="home-sidebar-desc">Tu punto de partida para explorar comunidades técnicas, publicar preguntas y conectar con otros desarrolladores.</p>
                    <a href="@Url.Action("Create", "Post")" class="btn btn-primary-strong home-sidebar-btn">Crear publicación</a>
                    <a href="@Url.Action("Create", "Comunidad")" class="btn btn-ghost home-sidebar-btn">Crear comunidad</a>
                </div>
            </aside>
        }
        else
        {
            <aside class="home-sidebar-card surface-card">
                <div class="home-sidebar-banner" aria-hidden="true"></div>
                <div class="home-sidebar-body">
                    <h6 class="home-sidebar-title">Únete a la comunidad</h6>
                    <p class="home-sidebar-desc">Crea una cuenta para publicar preguntas, responder comentarios y votar en el foro.</p>
                    <a href="@Url.Action("Register", "Account")" class="btn btn-primary-strong home-sidebar-btn">Registrarse</a>
                    <a href="@Url.Action("Login", "Account")" class="btn btn-ghost home-sidebar-btn">Iniciar sesión</a>
                </div>
            </aside>
        }
    </div>

</div>