<section class="hero-panel">
    <div class="hero-content">
        <h1 id="title">Foro Readme</h1>
        <p class="lead">Comparte ideas, resuelve dudas y participa en debates con una comunidad técnica activa.</p>
        @if (Session["UsuarioId"] != null)
        {
            <p class="welcome-text">Bienvenido de vuelta, <strong>@Session["NombreUsuario"]</strong>.</p>
            <div class="hero-actions">
                <a href="@Url.Action("Index", "Comunidad")" class="btn btn-primary-strong">Explorar comunidades</a>
                <a href="@Url.Action("Create", "Comunidad")" class="btn btn-ghost">Crear comunidad</a>
            </div>
        }
        else
        {
            <p class="welcome-text">Inicia sesión para publicar, comentar y reaccionar en el foro.</p>
            <div class="hero-actions">
                <a href="@Url.Action("Login", "Account")" class="btn btn-primary-strong">Iniciar sesión</a>
                <a href="@Url.Action("Register", "Account")" class="btn btn-ghost">Registrarse</a>
            </div>
        }
    </div>
</section>

<div class="row forum-home-grid">
    <div class="col-md-8">
        <section class="surface-card">
            <h3>Actividad principal</h3>
            <p>Ingresa a una comunidad para ver publicaciones, responder comentarios y participar en conversaciones.</p>
            <a href="@Url.Action("Index", "Comunidad")" class="btn btn-primary-strong">Ir a comunidades</a>
        </section>
    </div>

    <div class="col-md-4">
        <section class="surface-card">
            <h3>Atajos</h3>
            <ul class="clean-list">
                <li>Publica una pregunta técnica</li>
                <li>Responde con soluciones claras</li>
                <li>Reacciona a comentarios útiles</li>
            </ul>
            <a href="@Url.Action("Index", "Comunidad")" class="btn btn-ghost btn-block">Elegir comunidad para publicar</a>
        </section>
    </div>
</div>