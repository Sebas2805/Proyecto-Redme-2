@using Proyecto.MVC.Helpers
@model Proyecto.Data.comentario

@{
    ViewBag.Title = "Detalle del comentario";
}

<h2>Detalle del comentario</h2>

<div>
    <hr />
    <dl class="dl-horizontal">
        <dt>
            @Html.DisplayNameFor(model => model.contenido)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.contenido)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.fecha_comentario)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.fecha_comentario)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.comentario2.contenido)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.comentario2.contenido)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.post.titulo)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.post.titulo)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.usuario.nombre_usuario)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.usuario.nombre_usuario)
        </dd>

    </dl>
</div>
<p>
    @if (SessionHelper.UsuarioId == Model.id_usuario)
    {
        @Html.ActionLink("Editar", "Edit", new { id = Model.id_comentario })
        <text> | </text>
    }
    @Html.ActionLink("Volver al hilo", "Index", new { postId = Model.id_post })
