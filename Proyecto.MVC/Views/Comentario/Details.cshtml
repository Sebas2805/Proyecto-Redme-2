@using Proyecto.MVC.Helpers
@model Proyecto.Data.comentario

@{
    ViewBag.Title = "Detalle del comentario";
}

<section class="page-header-row">
    <div>
        <h2>Detalle del comentario</h2>
    </div>
    @Html.ActionLink("Volver al hilo", "Index", new { postId = Model.id_post }, new { @class = "btn btn-ghost btn-sm" })
</section>

<section class="surface-card">
    <div class="feed-card-main">
        <p class="thread-comment-bodyText">@Html.DisplayFor(model => model.contenido)</p>
        <div class="detail-grid">
            <div class="detail-item">
                <strong>Fecha</strong>
                <p>@Html.DisplayFor(model => model.fecha_comentario)</p>
            </div>
            <div class="detail-item">
                <strong>Post</strong>
                <p>@Html.DisplayFor(model => model.post.titulo)</p>
            </div>
            <div class="detail-item">
                <strong>Autor</strong>
                <p>@Html.DisplayFor(model => model.usuario.nombre_usuario)</p>
            </div>
        </div>
    </div>
    @if (SessionHelper.UsuarioId == Model.id_usuario)
    {
        <div class="form-submit-row">
            @Html.ActionLink("Editar", "Edit", new { id = Model.id_comentario }, new { @class = "btn btn-ghost btn-sm" })
        </div>
    }
</section>
