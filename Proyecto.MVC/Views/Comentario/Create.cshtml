@model Proyecto.Data.comentario

@{
    ViewBag.Title = "Nuevo comentario";
    int postId = (int)ViewBag.PostId;
}

<section class="page-header-row">
    <div>
        <h2>Nuevo comentario</h2>
        <p>Añade tu respuesta al hilo.</p>
    </div>
    @Html.ActionLink("Volver al hilo", "Index", new { postId = postId }, new { @class = "btn btn-ghost btn-sm" })
</section>

<div class="surface-card form-page-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("postId", postId)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.contenido)
            @Html.TextAreaFor(model => model.contenido, new { @class = "form-control", rows = 5, placeholder = "Escribe tu comentario..." })
            @Html.ValidationMessageFor(model => model.contenido, "", new { @class = "text-danger" })
        </div>

        <div class="form-submit-row">
            <button type="submit" class="btn btn-primary-strong">Comentar</button>
            @Html.ActionLink("Cancelar", "Index", new { postId = postId }, new { @class = "btn btn-ghost" })
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
