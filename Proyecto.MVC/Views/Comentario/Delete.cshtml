@model Proyecto.Data.comentario

@{
    ViewBag.Title = "Eliminar comentario";
}

<section class="page-header-row">
    <div>
        <h2>Eliminar comentario</h2>
        <p>Esta acción no se puede deshacer.</p>
    </div>
</section>

<div class="surface-card confirm-card">
    <div class="confirm-field">
        <div class="confirm-field-label">Contenido</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.contenido)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Fecha</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.fecha_comentario)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Post</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.post.titulo)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Autor</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.usuario.nombre_usuario)</div>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="confirm-actions">
            <button type="submit" class="btn btn-danger-soft">Eliminar comentario</button>
            @Html.ActionLink("Cancelar", "Index", new { postId = Model.id_post }, new { @class = "btn btn-ghost" })
        </div>
    }
</div>
