@model IEnumerable<Proyecto.Data.comentario>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.contenido)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.fecha_comentario)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.comentario2.contenido)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.post.titulo)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.usuario.nombre_usuario)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.contenido)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.fecha_comentario)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.comentario2.contenido)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.post.titulo)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.usuario.nombre_usuario)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.id_comentario }) |
            @Html.ActionLink("Details", "Details", new { id=item.id_comentario }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.id_comentario })
        </td>
    </tr>
}

</table>
