@model Proyecto.ForoReadme.Models.LoginViewModel
@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-shell">
    <div class="auth-card login-card">
        <h2>Iniciar sesión</h2>
        <p>Accede para publicar, responder y reaccionar.</p>

        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="form-group">
                @Html.LabelFor(m => m.Email)
                @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Ingresa tu correo electrónico" })
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Password)
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Ingresa tu contraseña" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
            </div>

            <div class="checkbox">
                <label>@Html.CheckBoxFor(m => m.RememberMe) Recordarme</label>
            </div>

            <button type="submit" class="btn btn-primary-strong btn-block">Entrar</button>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger auth-alert">
                @Html.ValidationSummary(true, "No se pudo iniciar sesión. Corrige los errores e inténtalo de nuevo.")
            </div>
        }

        <p class="auth-switch">
            ¿No tienes cuenta?
            @Html.ActionLink("Regístrate aquí", "Register", "Account")
        </p>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}