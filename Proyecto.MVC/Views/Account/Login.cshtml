@model Proyecto.ForoReadme.Models.LoginViewModel
@{
    ViewBag.Title = "Iniciar Sesión";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-md-4 col-md-offset-4">

        <div class="login-box">

            <h2 class="text-center">Iniciar Sesión</h2>
            <hr />

            @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post))
            {
                <div class="form-group">
                    @Html.LabelFor(m => m.Email)
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Ingrese su email" })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    @Html.LabelFor(m => m.Password)
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", placeholder = "Ingrese su contraseña" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="checkbox">
                    <label>
                        @Html.CheckBoxFor(m => m.RememberMe) Recordarme
                    </label>
                </div>

                <button type="submit" class="btn btn-primary btn-block">
                    Iniciar Sesión
                </button>
            }

            @* Validación fuera del BeginForm para evitar errores Razor *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" style="margin-top:15px;">
                    @Html.ValidationSummary(true, "No se pudo iniciar sesión. Corrija los errores e intente nuevamente.")
                </div>
            }

            <hr />

            <p class="text-center">
                ¿No tienes una cuenta?
                @Html.ActionLink("Regístrate aquí", "Register", "Account")
            </p>

        </div>

    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}