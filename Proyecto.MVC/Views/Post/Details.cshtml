@using Proyecto.MVC.Helpers
@model Proyecto.Data.post

@{
    ViewBag.Title = "Detalle del post";
    var returnUrl = Request.QueryString["returnUrl"];
}

<div style="max-width:700px; margin:20px auto 0; font-family:Arial, sans-serif;">
    <a href="@(string.IsNullOrEmpty(returnUrl) ? "javascript:history.back()" : returnUrl)" style="
        display:inline-flex;
        align-items:center;
        gap:6px;
        text-decoration:none;
        color:#555;
        font-size:14px;
        padding:8px 14px;
        border:1px solid #ccc;
        border-radius:8px;
        background:#f9f9f9;
        transition:all 0.2s;
    " onmouseover="this.style.background='#eee'; this.style.borderColor='#aaa';"
       onmouseout="this.style.background='#f9f9f9'; this.style.borderColor='#ccc';">
        ← Volver
    </a>
</div>

<section class="page-header-row">
    <div>
        <h2>@Model.titulo</h2>
        <p>Detalle de la publicación</p>
    </div>
</section>

<section class="surface-card">

    <div class="feed-card-main">

        <h3>Contenido</h3>
        <p>@Model.contenido</p>

        <hr />

        <div class="detail-grid">

            <div class="detail-item">
                <strong>Comunidad</strong>
                <p>@Model.comunidad.nombre</p>
            </div>

            <div class="detail-item">
                <strong>Autor</strong>
                <p>@Model.usuario.nombre_usuario</p>
            </div>

            <div class="detail-item">
                <strong>Fecha de publicación</strong>
                <p>@Model.fecha_publicacion</p>
            </div>

        </div>

    </div>

    <div class="feed-card-actions">

        @Html.ActionLink("Ver conversación",
            "Index",
            "Comentario",
            new { postId = Model.id_post },
            new { @class = "btn btn-primary-strong btn-sm" })

        @if (SessionHelper.UsuarioId == Model.id_usuario)
        {
            @Html.ActionLink("Editar",
                "Edit",
                "Post",
                new { id = Model.id_post },
                new { @class = "btn btn-ghost btn-sm" })

            @Html.ActionLink("Eliminar",
                "Delete",
                "Post",
                new { id = Model.id_post },
                new { @class = "btn btn-danger-soft btn-sm" })
        }

        @Html.ActionLink("Volver a posts",
            "Index",
            "Post",
            new { comunidadId = Model.id_comunidad },
            new { @class = "btn btn-ghost btn-sm" })

    </div>

</section>