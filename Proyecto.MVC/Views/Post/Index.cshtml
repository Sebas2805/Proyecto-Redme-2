@model IEnumerable<Proyecto.Data.post>

@{
    ViewBag.Title = "Posts";
}

@{
    int comunidadId = (int)ViewBag.ComunidadId;
}

<section class="page-header-row">
    <div>
        <h2>Publicaciones</h2>
        <p>Conversaciones activas dentro de esta comunidad.</p>
    </div>
    @Html.ActionLink("Nueva publicación", "Create", "Post", new { comunidadId = comunidadId }, new { @class = "btn btn-primary-strong" })
</section>

@if (!Model.Any())
{
    <section class="surface-card">
        <p>No hay publicaciones todavía.</p>
    </section>
}
else
{
    foreach (var item in Model)
    {
        <article class="feed-card">
            <div class="feed-card-main">
                <h3>@item.titulo</h3>
                <p>@item.contenido</p>
                <div class="meta-row">
                    <span><strong>Comunidad:</strong> @item.comunidad.nombre</span>
                    <span><strong>Autor:</strong> @item.usuario.nombre_usuario</span>
                    <span><strong>Fecha:</strong> @item.fecha_publicacion</span>
                </div>
            </div>
            <div class="feed-card-actions">
                @Html.ActionLink("Comentarios", "Index", "Comentario", new { postId = item.id_post }, new { @class = "btn btn-primary-strong btn-sm" })
                @Html.ActionLink("Editar", "Edit", new { id = item.id_post }, new { @class = "btn btn-ghost btn-sm" })
                @Html.ActionLink("Detalle", "Details", new { id = item.id_post }, new { @class = "btn btn-ghost btn-sm" })
                @Html.ActionLink("Eliminar", "Delete", new { id = item.id_post }, new { @class = "btn btn-danger-soft btn-sm" })
            </div>
        </article>
    }
}
