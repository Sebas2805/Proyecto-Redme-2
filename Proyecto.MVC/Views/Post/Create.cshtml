@model Proyecto.Data.post

@{
    ViewBag.Title = "Crear publicación";
}

<section class="page-header-row">
    <div>
        <h2>Nueva publicación</h2>
        <p>Comparte una pregunta, idea o debate con la comunidad.</p>
    </div>
    @Html.ActionLink("Volver a posts", "Index", new { comunidadId = ViewBag.ComunidadId }, new { @class = "btn btn-ghost btn-sm" })
</section>

<div class="surface-card form-page-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("comunidadId", (int)ViewBag.ComunidadId)
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.titulo)
            @Html.EditorFor(model => model.titulo, new { htmlAttributes = new { @class = "form-control", placeholder = "Título de la publicación" } })
            @Html.ValidationMessageFor(model => model.titulo, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.contenido)
            @Html.TextAreaFor(model => model.contenido, new { @class = "form-control", rows = 6, placeholder = "Escribe el contenido aquí..." })
            @Html.ValidationMessageFor(model => model.contenido, "", new { @class = "text-danger" })
        </div>

        <div class="form-submit-row">
            <button type="submit" class="btn btn-primary-strong">Publicar</button>
            @Html.ActionLink("Cancelar", "Index", new { comunidadId = ViewBag.ComunidadId }, new { @class = "btn btn-ghost" })
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}