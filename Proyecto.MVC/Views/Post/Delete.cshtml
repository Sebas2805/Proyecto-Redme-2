@model Proyecto.Data.post

@{
    ViewBag.Title = "Eliminar publicación";
}

<section class="page-header-row">
    <div>
        <h2>Eliminar publicación</h2>
        <p>Esta acción no se puede deshacer.</p>
    </div>
</section>

<div class="surface-card confirm-card">
    <div class="confirm-field">
        <div class="confirm-field-label">Título</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.titulo)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Contenido</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.contenido)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Comunidad</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.comunidad.nombre)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Autor</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.usuario.nombre_usuario)</div>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="confirm-actions">
            <button type="submit" class="btn btn-danger-soft">Eliminar publicación</button>
            @Html.ActionLink("Cancelar", "Index", new { comunidadId = Model.id_comunidad }, new { @class = "btn btn-ghost" })
        </div>
    }
</div>
