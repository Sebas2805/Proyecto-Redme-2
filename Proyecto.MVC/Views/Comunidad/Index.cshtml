@model IEnumerable<Proyecto.Data.comunidad>

@{
    ViewBag.Title = "Comunidades";
}

<section class="page-header-row">
    <div>
        <h2>Comunidades</h2>
        <p>Explora espacios temáticos y participa en discusiones.</p>
    </div>
    @Html.ActionLink("Crear comunidad", "Create", null, new { @class = "btn btn-primary-strong" })
</section>

@if (!Model.Any())
{
    <section class="surface-card">
        <p>Aún no hay comunidades registradas.</p>
    </section>
}
else
{
    foreach (var item in Model)
    {
        <article class="feed-card">
            <div class="feed-card-main">
                <h3>@item.nombre</h3>
                <p>@item.descripcion</p>
            </div>
            <div class="feed-card-actions">
                @Html.ActionLink("Ver posts", "Index", "Post", new { comunidadId = item.id_comunidad }, new { @class = "btn btn-primary-strong btn-sm" })
                @Html.ActionLink("Editar", "Edit", new { id = item.id_comunidad }, new { @class = "btn btn-ghost btn-sm" })
                @Html.ActionLink("Detalle", "Details", new { id = item.id_comunidad }, new { @class = "btn btn-ghost btn-sm" })
                @Html.ActionLink("Eliminar", "Delete", new { id = item.id_comunidad }, new { @class = "btn btn-danger-soft btn-sm" })
            </div>
        </article>
    }
}
