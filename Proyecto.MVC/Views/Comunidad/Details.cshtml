@model Proyecto.Data.comunidad

@{
    ViewBag.Title = "Detalle de comunidad";
}

<section class="page-header-row">
    <div>
        <h2>@Model.nombre</h2>
        <p>Información de la comunidad</p>
    </div>
</section>

<section class="surface-card">

    <div class="feed-card-main">

        <h3>Descripción</h3>
        <p>@Model.descripcion</p>

        <hr />

        <div class="detail-grid">

            <div class="detail-item">
                <strong>Fecha de creación</strong>
                <p>@Model.fecha_creacion</p>
            </div>

            <div class="detail-item">
                <strong>Creador</strong>
                <p>@Model.usuario.nombre_usuario</p>
            </div>

        </div>

    </div>

    <div class="feed-card-actions">

        @Html.ActionLink("Editar", "Edit",
            new { id = Model.id_comunidad },
            new { @class = "btn btn-ghost btn-sm" })

        @Html.ActionLink("Eliminar", "Delete",
            new { id = Model.id_comunidad },
            new { @class = "btn btn-danger-soft btn-sm" })

        @Html.ActionLink("Volver", "Index",
            null,
            new { @class = "btn btn-primary-strong btn-sm" })

    </div>

</section>