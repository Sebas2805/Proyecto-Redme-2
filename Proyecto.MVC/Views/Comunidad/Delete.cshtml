@model Proyecto.Data.comunidad

@{
    ViewBag.Title = "Eliminar comunidad";
}

<section class="page-header-row">
    <div>
        <h2>Eliminar comunidad</h2>
        <p>Esta acción no se puede deshacer.</p>
    </div>
</section>

<div class="surface-card confirm-card">
    <div class="confirm-field">
        <div class="confirm-field-label">Nombre</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.nombre)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Descripción</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.descripcion)</div>
    </div>
    <div class="confirm-field">
        <div class="confirm-field-label">Creador</div>
        <div class="confirm-field-value">@Html.DisplayFor(model => model.usuario.nombre_usuario)</div>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="confirm-actions">
            <button type="submit" class="btn btn-danger-soft">Eliminar comunidad</button>
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-ghost" })
        </div>
    }
</div>
