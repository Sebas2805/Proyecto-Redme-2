@model Proyecto.Data.comunidad

@{
    ViewBag.Title = "Crear comunidad";
}

<section class="page-header-row">
    <div>
        <h2>Crear comunidad</h2>
        <p>Crea un nuevo espacio temático para tu comunidad.</p>
    </div>
    @Html.ActionLink("Volver", "Index", null, new { @class = "btn btn-ghost btn-sm" })
</section>

<div class="surface-card form-page-card">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.nombre)
            @Html.EditorFor(model => model.nombre, new { htmlAttributes = new { @class = "form-control", placeholder = "Nombre de la comunidad" } })
            @Html.ValidationMessageFor(model => model.nombre, "", new { @class = "text-danger" })
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.descripcion)
            @Html.TextAreaFor(model => model.descripcion, new { @class = "form-control", rows = 4, placeholder = "Descripción de la comunidad" })
            @Html.ValidationMessageFor(model => model.descripcion, "", new { @class = "text-danger" })
        </div>

        <div class="form-submit-row">
            <button type="submit" class="btn btn-primary-strong">Crear comunidad</button>
            @Html.ActionLink("Cancelar", "Index", null, new { @class = "btn btn-ghost" })
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
