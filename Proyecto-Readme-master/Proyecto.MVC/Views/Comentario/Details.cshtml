@model Proyecto.Data.comentario

@{
    ViewBag.Title = "Details";
}

<h2>Detalle del Comentario</h2>

<div>
    <h4>Comentario</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>@Html.DisplayNameFor(model => model.contenido)</dt>
        <dd>@Html.DisplayFor(model => model.contenido)</dd>

        <dt>@Html.DisplayNameFor(model => model.fecha_comentario)</dt>
        <dd>@Html.DisplayFor(model => model.fecha_comentario)</dd>

        <dt>@Html.DisplayNameFor(model => model.comentario2.contenido)</dt>
        <dd>@Html.DisplayFor(model => model.comentario2.contenido)</dd>

        <dt>@Html.DisplayNameFor(model => model.post.titulo)</dt>
        <dd>@Html.DisplayFor(model => model.post.titulo)</dd>

        <dt>@Html.DisplayNameFor(model => model.usuario.nombre_usuario)</dt>
        <dd>@Html.DisplayFor(model => model.usuario.nombre_usuario)</dd>
    </dl>

    <!-- Botones Like/Dislike con contadores -->
    <div class="form-group" style="margin-top:10px;">
        <button type="button" onclick="votarComentario(@Model.id_comentario, 'like')" class="btn btn-success btn-sm">
            👍 Like (<span id="likes-@Model.id_comentario">@Model.voto.Count(v => v.tipo == "like")</span>)
        </button>
        <button type="button" onclick="votarComentario(@Model.id_comentario, 'dislike')" class="btn btn-danger btn-sm">
            👎 Dislike (<span id="dislikes-@Model.id_comentario">@Model.voto.Count(v => v.tipo == "dislike")</span>)
        </button>
    </div>
</div>

<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.id_comentario }) |
    @Html.ActionLink("Back to List", "Index")
</p>

@section Scripts {
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script>
        function votarComentario(idComentario, tipo) {
            $.ajax({
                url: '/Post/ReaccionarComentario',
                type: 'POST',
                data: { idComentario: idComentario, tipo: tipo },
                success: function (response) {
                    if (response.success) {
                        // Actualiza los contadores
                        let likes = parseInt($("#likes-" + idComentario).text());
                        let dislikes = parseInt($("#dislikes-" + idComentario).text());

                        if (tipo === "like") {
                            if (response.cambio === "nuevo" || response.cambio === "like") likes++;
                            if (response.cambio === "dislike") { likes++; dislikes--; }
                        }
                        if (tipo === "dislike") {
                            if (response.cambio === "nuevo" || response.cambio === "dislike") dislikes++;
                            if (response.cambio === "like") { dislikes++; likes--; }
                        }

                        $("#likes-" + idComentario).text(likes);
                        $("#dislikes-" + idComentario).text(dislikes);

                        alert(response.message);
                    } else {
                        alert("Error: " + response.message);
                    }
                },
                error: function () {
                    alert("Error en la solicitud.");
                }
            });
        }
    </script>
}